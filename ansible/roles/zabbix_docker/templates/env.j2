POSTGRES_DB={{ zabbix_postgres_db | default('zabbix') }}
POSTGRES_USER={{ zabbix_postgres_user | default('zabbix') }}
POSTGRES_PASSWORD={{ zabbix_postgres_password }}

PHP_TZ={{ zabbix_php_tz | default('Europe/Nicosia') }}
ZABBIX_WEB_PORT={{ zabbix_web_port | default(8080) }}
ZABBIX_HTTPS_PORT={{ zabbix_https_port | default(8443) }}
ZABBIX_SERVER_PORT={{ zabbix_server_port | default(10051) }}
ZABBIX_SSL_DIR={{ zabbix_ssl_dir | default('/opt/zabbix/ssl') }}
ZABBIX_IMAGE_TAG={{ zabbix_image_tag | default('ubuntu-7.4.8') }}
POSTGRES_IMAGE_TAG={{ postgres_image_tag | default('16-alpine') }}
DOCKER_LOG_MAX_SIZE={{ docker_log_max_size | default('10m') }}
DOCKER_LOG_MAX_FILE={{ docker_log_max_file | default(5) }}

ZBX_AGENT_HOSTNAME={{ zabbix_agent_hostname | default('docker-zabbix-server') }}
ZBX_ENABLE_SNMP_TRAPS={{ zabbix_enable_snmp_traps | default(false) | lower }}

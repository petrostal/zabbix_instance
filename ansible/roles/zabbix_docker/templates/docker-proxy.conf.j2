[Service]
Environment="HTTP_PROXY={{ zabbix_proxy_env.HTTP_PROXY | default(zabbix_proxy_env.http_proxy) }}"
Environment="HTTPS_PROXY={{ zabbix_proxy_env.HTTPS_PROXY | default(zabbix_proxy_env.https_proxy) }}"
Environment="NO_PROXY={{ zabbix_proxy_env.NO_PROXY | default(zabbix_proxy_env.no_proxy | default('localhost,127.0.0.1,::1')) }}"
